#include <physical_layouts.dtsi>

/ {
    klor_saegewerk_layout: klor_saegewerk_layout {
        compatible = "zmk,physical-layout";
        display-name = "Saegewerk";

        keys = <
            /* Row 0 - top row, 5+5, no outer pinky */
            /* w    h    x     y     r   rx    ry  */
            &key_physical_attrs 100 100  100    0   0    0    0  /* Q */
            &key_physical_attrs 100 100  200    0   0    0    0  /* W */
            &key_physical_attrs 100 100  300    0   0    0    0  /* E */
            &key_physical_attrs 100 100  400    0   0    0    0  /* R */
            &key_physical_attrs 100 100  500    0   0    0    0  /* T */
            &key_physical_attrs 100 100  700    0   0    0    0  /* Y */
            &key_physical_attrs 100 100  800    0   0    0    0  /* U */
            &key_physical_attrs 100 100  900    0   0    0    0  /* I */
            &key_physical_attrs 100 100 1000    0   0    0    0  /* O */
            &key_physical_attrs 100 100 1100    0   0    0    0  /* P */

            /* Row 1 - home row, 5+5, no outer pinky */
            &key_physical_attrs 100 100  100  100   0    0    0  /* A */
            &key_physical_attrs 100 100  200  100   0    0    0  /* S */
            &key_physical_attrs 100 100  300  100   0    0    0  /* D */
            &key_physical_attrs 100 100  400  100   0    0    0  /* F */
            &key_physical_attrs 100 100  500  100   0    0    0  /* G */
            &key_physical_attrs 100 100  700  100   0    0    0  /* H */
            &key_physical_attrs 100 100  800  100   0    0    0  /* J */
            &key_physical_attrs 100 100  900  100   0    0    0  /* K */
            &key_physical_attrs 100 100 1000  100   0    0    0  /* L */
            &key_physical_attrs 100 100 1100  100   0    0    0  /* ; */

            /* Row 2 - bottom row, 5+5, no outer pinky */
            &key_physical_attrs 100 100  100  200   0    0    0  /* Z */
            &key_physical_attrs 100 100  200  200   0    0    0  /* X */
            &key_physical_attrs 100 100  300  200   0    0    0  /* C */
            &key_physical_attrs 100 100  400  200   0    0    0  /* V */
            &key_physical_attrs 100 100  500  200   0    0    0  /* B */
            &key_physical_attrs 100 100  700  200   0    0    0  /* N */
            &key_physical_attrs 100 100  800  200   0    0    0  /* M */
            &key_physical_attrs 100 100  900  200   0    0    0  /* , */
            &key_physical_attrs 100 100 1000  200   0    0    0  /* . */
            &key_physical_attrs 100 100 1100  200   0    0    0  /* / */

            /* Thumb row - 3+3 */
            &key_physical_attrs 100 100  300  325   0    0    0  /* LCTRL */
            &key_physical_attrs 100 100  400  350   0    0    0  /* LOWER */
            &key_physical_attrs 100 100  500  375   0    0    0  /* SPACE */
            &key_physical_attrs 100 100  700  375   0    0    0  /* ENTER */
            &key_physical_attrs 100 100  800  350   0    0    0  /* RAISE */
            &key_physical_attrs 100 100  900  325   0    0    0  /* BSPC */
        >;
    };
};
