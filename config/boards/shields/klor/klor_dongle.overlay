/ {
    chosen {
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = 
            0x0001 0x0002 0x0003 0x0004 0x0005                           0x0006 0x0007 0x0008 0x0009 0x000A
0x0100 0x0101 0x0102 0x0103 0x0104 0x0105                           0x0106 0x0107 0x0108 0x0109 0x010A 0x010B
0x0200 0x0201 0x0202 0x0203 0x0204 0x0205 0x0305 0x0306 0x0206 0x0207 0x0208 0x0209 0x020A 0x020B
                            0x0301 0x0302 0x0303 0x0304 0x0307 0x0308 0x0309 0x030A
        >;
    };
};